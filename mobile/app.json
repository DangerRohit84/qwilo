{
  "expo": {
    "name": "Qwilo",
    "slug": "qwilo",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon_1024.png",
    "userInterfaceStyle": "automatic",
    "scheme": "qwilo",
    "splash": {
      "image": "./assets/logo_with_name_qwilo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qwilo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.qwilo.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiUrl": "https://qwilo.onrender.com/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8138dd0b-e399-42b1-89ef-a3b2b5021e74"
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice answers."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "owner": "danger_rohit_84"
  }
}
