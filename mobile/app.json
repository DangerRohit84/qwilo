{
  "expo": {
    "name": "Qwilo",
    "slug": "qwilo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "scheme": "qwilo",
    "splash": {
      "image": "./assets/logo_with_name_qwilo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qwilo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.qwilo.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "extra": {
      "apiUrl": "http://192.168.1.5:4000/api",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "59fc43d2-bbdc-45f8-9a6d-b52c63612be3"
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for voice answers."
        }
      ],
      "expo-asset"
    ],
    "owner": "danger_rohit_84"
  }
}
